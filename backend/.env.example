# Server Configuration
PORT=3000

# Database Configuration
MONGO_URI=mongodb://localhost:27017/clinic-appointment

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key

# Twilio SMS Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
